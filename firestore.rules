rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/favorites/{lineId}
    // Document ID: lineId
    // Fields:
    //   - lineId: string (required) - The unique ID of the bus route.
    //   - lineNo: string (required) - The display number of the bus route.
    //   - createdAt: timestamp (required) - When the favorite was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "k9211255@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['lineId', 'lineNo', 'createdAt']) &&
             data.lineId is string && data.lineId.size() > 0 &&
             data.lineNo is string && data.lineNo.size() > 0 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId}/favorites/{lineId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidFavorite(request.resource.data);
      allow update: if isOwner(userId) && isValidFavorite(request.resource.data) &&
                      request.resource.data.lineId == resource.data.lineId;
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
